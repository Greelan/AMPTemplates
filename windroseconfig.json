        "FieldName": "UseDirectConnection",
        "InputType": "enum",
        "ParamFieldName": "$.ServerDescription_Persistent.UseDirectConnection",
        "DefaultValue": "false",
        "EnumValues": {
            "false": "P2P Connection (default)",
            "true": "Direct Port Connection"
        }
    },
    {
