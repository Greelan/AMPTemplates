Meta.DisplayName=Subnautica 2 (BeaconServer)
Meta.Description=Subnautica 2 Dedicated Server using BeaconServer
Meta.OS=
Meta.AarchSupport=Unknown
Meta.Arch=x86_64
Meta.Author=Greelan
Meta.URL=https://github.com/humangenome/BeaconServer
