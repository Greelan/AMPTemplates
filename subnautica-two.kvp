Meta.ImportableExtensions=[".txt"]
Meta.AppIsMultiIPAware=False
App.DisplayName=Subnautica 2
App.RootDir=./subnautica2/
App.BaseDirectory=./subnautica2/server/
App.StoresSupported=None
