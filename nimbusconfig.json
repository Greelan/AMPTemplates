        "DisplayName": "Admin Binding",                 
        "Category": "Nimbus:stadia_controller",           
        "Subcategory": "Server:dns:1",                    
        "Description": "Sets the IP binding for the admin interface (will listen on the Admin Port). Keep on localhost unless you have an authenticated reverse proxy in front",                                        
