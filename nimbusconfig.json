        "EnumValues": {}                                  
    },   
    {
        "DisplayName": "Metrics Binding",                 
        "Category": "Nimbus:stadia_controller",           
        "Subcategory": "Server:dns:1",                    
        "Description": "Sets the URL for a Prometheus text endpoint (will listen on the Metrics Port). Counters include: sessions accepted/closed, backend connect attempts/successes/failures, redirect and seamless counts, bytes proxied, transfer intents dispatched, drained backends",                                        
        "Keywords": "metrics,bind,prometheus",            
        "FieldName": "MetricsBinding",                    
        "InputType": "text",                              
        "ParamFieldName": "MetricsBinding",               
        "DefaultValue": "http://127.0.0.1",               
        "Placeholder": "http://127.0.0.1",                
        "EnumValues": {}                                  
    },                   
    {
        "DisplayName": "Registry Binding",
        "Category": "Nimbus:stadia_controller",
        "Subcategory": "Server:dns:1",
        "Description": "Sets the Kestrel bind URL for the embedded registry HTTP API (will listen on the Registry Port). Set to empty to disable the HTTP listener entirely - backends on the same host can reach the registry in-process; external backends have nowhere to heartbeat",
        "Keywords": "registry,embedded,bind",
        "FieldName": "RegistryBinding",
        "InputType": "text",
        "ParamFieldName": "RegistryBinding",
        "DefaultValue": "http://0.0.0.0",
        "Placeholder": "http://0.0.0.0",
        "EnumValues": {}
    },
    {
        "DisplayName": "Embedded Registry Shared Secret",
        "Category": "Nimbus:stadia_controller",
        "Subcategory": "Server:dns:1",
        "Description": "Sets the embedded registry HMAC secret. Must match 'SharedSecret' in every backend's nimbus-server.json. Default is a strong random value",
